{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/calendar",
      "destination": "/api/calendar"
    },
    {
      "source": "/api/news",
      "destination": "/api/news"
    },
    {
      "source": "/api/trigger-scrape",
      "destination": "/api/trigger-scrape"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
