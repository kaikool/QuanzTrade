# DeepL translates RSS titles and summaries into Vietnamese on the server.
DEEPL_API_KEY="MY_DEEPL_API_KEY"

# Optional. Free DeepL keys usually use api-free automatically (:fx key suffix).
# Set this to https://api.deepl.com if you use a paid key and auto-detection is wrong.
DEEPL_API_URL="https://api-free.deepl.com"
DEEPL_TRANSLATION_BATCH_LIMIT="30"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MARKETAUX_API_KEY: Optional. Enables scored financial news from Marketaux.
MARKETAUX_API_KEY="MY_MARKETAUX_API_KEY"

# Server-side Supabase cache for translated RSS news.
# Use service role key only in server/Vercel env, never expose it to the browser.
SUPABASE_URL="MY_SUPABASE_URL"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"
